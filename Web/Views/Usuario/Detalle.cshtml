@model Skart.Entities.Usuario
@{
    ViewBag.Title = "Detalle Usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h2>Detalle Usuario</h2>
</div>

<div class="details-card">
    <div class="detail-row">
        <span class="detail-label">ID:</span>
        <span class="detail-value">@Model.UsuarioId</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Nombre Usuario:</span>
        <span class="detail-value">@Model.NombreUsuario</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Email:</span>
        <span class="detail-value">@Model.Email</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Fecha Registro:</span>
        <span class="detail-value">@Model.FechaRegistro.ToString("dd/MM/yyyy")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Estado:</span>
        <span class="detail-value">@(Model.Estado ? "Activo" : "Inactivo")</span>
    </div>
</div>

<div class="actions-bar">
    @Html.ActionLink("✏️ Editar", "Editar", new { id = Model.UsuarioId }, new { @class = "btn btn-warning" })
    @Html.ActionLink("⬅️ Volver", "Index", null, new { @class = "btn btn-secondary" })
</div>